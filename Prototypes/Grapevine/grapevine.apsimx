                            0.95,
                            1.0,
                            1.05,
                            1.1,
                            1.2,
                            1.3
                          ],
                          "Name": "XYPairs",
                          "Children": [],
                          "IncludeInDocumentation": true,
                          "Enabled": true,
                          "ReadOnly": false
                        }
                      ],
                      "IncludeInDocumentation": true,
                      "Enabled": true,
                      "ReadOnly": false
                    },
