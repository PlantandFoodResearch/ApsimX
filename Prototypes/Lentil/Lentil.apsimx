                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.PMF.Phen;",
                    "using System;",
                    "using Models.Core;",
                    "using System.Collections.Generic;",
                    "using System.Text;",
                    "using Models.Soils;",
                    "using Models.PMF;",
                    "using Models;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using Newtonsoft.Json;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable] ",
                    "    public class Script : Model",
                    "    {      ",
                    "        [Link] private Plant Lentil;",
                    "        [Link] private Zone zone;",
                    "        [Link(Type = LinkType.Path, Path = \"[Lentil].Phenology\")]",
                    "        private Phenology phenology;",
                    "        [Link] private Simulation sim;",
                    "        [Link] private Clock Clock;",
                    "        [JsonIgnore] public bool Harvested { get; set; }",
                    "        [JsonIgnore] public bool EndSet { get; set; }",
                    "        ",
                    "        [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void OnSimulationCommencing(object sender, EventArgs e)",
                    "        {",
                    "        \tHarvested = false;",
                    "            EndSet = false;",
                    "        }       ",
                    "        ",
                    "        [EventSubscribe(\"DoManagement\")]",
                    "        private void OnDoManagement(object sender, EventArgs e)",
                    "        {",
                    "        \tif (phenology.CurrentPhase.Name==\"ReadyForHarvesting\")",
                    "           {",
                    "\t\t       Lentil.Harvest();",
                    "\t\t       Lentil.EndCrop();",
                    "\t\t       Harvested = true;",
                    "           }",
                    "           ",
                    "\t\t   if ((Harvested == true) && (EndSet == false))",
                    "\t\t   {",
                    "\t\t       sim.Set(\"Clock.EndDate\", Clock.Today.AddDays(1));",
                    "\t\t       EndSet = true;",
                    "\t\t   }",
                    "        }",
                    "        ",
                    "    }",
                    "}",
                    "       "
                  ],
                  "Parameters": [],
                  "Name": "Harvesting",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Report, Models",
                  "VariableNames": [
                    "[Clock].Today as Date",
                    "[Sowing].Script.CultivarName",
                    "[Sowing].Script.SowDate",
                    "[Lentil].Phenology.EmergenceDAS",
                    "[Lentil].Phenology.BuddingDAS",
                    "[Lentil].Phenology.FloweringDAS",
                    "[Lentil].Phenology.PoddingDAS",
                    "[Lentil].Phenology.MaturityDAS",
                    "[Lentil].Grain.Wt",
                    "[Lentil].Grain.Live.Wt",
                    "[Lentil].Grain.Size",
                    "[Lentil].AboveGround.Wt",
                    "[Lentil].Grain.HarvestIndex"
                  ],
                  "EventNames": [
                    "[Lentil].Harvesting"
                  ],
                  "GroupByVariableName": null,
                  "Name": "HarvestReport",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Report, Models",
                  "VariableNames": [
                    ""
                  ],
                  "EventNames": [
                    ""
                  ],
                  "GroupByVariableName": null,
                  "Name": "DailyReport",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": true,
                  "ReadOnly": false
