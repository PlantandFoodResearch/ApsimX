                  "AgeAtSimulationStart": 1.0,
                  "YearsToMaxDimension": 4,
                  "CrownShape": 1,
                  "MatureCanopyBaseHeight": 1.0,
                  "MaturePrunedCanopyBaseHeight": 1.5,
                  "MatureHeight": 3.5,
                  "MaturePrunedHeight": 3.0,
                  "MatureWidth": 3.0,
                  "MaturePrunedWidth": 2.0,
                  "SummerPruneDates": [
                    "1-dec"
                  ],
                  "FRemoveSummerPrune": 0.15,
                  "RootNConc": 0.01,
                  "LeafNConc": 0.02,
                  "WoodNConc": 0.005,
                  "FruitNConc": 0.02,
                  "NFixationFrac": 0.0,
                  "GRINZ": true,
                  "MaxRD": 3.0,
                  "ExtinctCoeff": 0.6,
                  "BaseCover": 0.0,
                  "MaxCover": 0.95,
                  "RUE": 1.2,
                  "PSBaseT": 5.0,
                  "PSLOptT": 20.0,
                  "PSUOptT": 25.0,
                  "PSMaxT": 35.0,
                  "GSMax": 0.006,
                  "R50": 100.0,
                  "SurfaceKL": 0.1,
                  "WaterStress": false,
                  "Number": 50,
                  "PotentialFWPerFruit": 70.0,
                  "DMC": 0.14,
                  "FruitDensity": 0.75,
                  "DateMaxBloom": "1-oct",
                  "DAFStartLinearGrowth": 30,
                  "DAFEndLinearGrowth": 90,
                  "DAFMaxSize": 150,
                  "Name": "Apple",
