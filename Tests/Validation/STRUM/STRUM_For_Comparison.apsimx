                {
                  "$type": "Models.PMF.SimplePlantModels.StrumTreeInstance, Models",
                  "TreeType": "Deciduous",
                  "RowSpacing": 4.0,
                  "InterRowSpacing": 4.0,
                  "AlleyZoneWidthFrac": 0.75,
                  "BudBreakDate": "19-Sep",
                  "StartFullCanopyDate": "24-Oct",
                  "StartLeafFallDate": "18-May",
                  "EndLeafFallDate": "20-Jun",
                  "DBHatMaturity": 5.0,
                  "TypicalCanopyArea": 16.0,
                  "WoodBulkDensity": 650.0,
                  "WoodStorageFraction": 0.2,
                  "MaximumLeafBiomass": 300.0,
                  "MaximumRootBiomass": 200.0,
                  "AgeAtSimulationStart": 2.0,
                  "YearsToMaxDimension": 6,
                  "CrownShape": 1,
                  "MatureCanopyBaseHeight": 1.0,
                  "MaturePrunedCanopyBaseHeight": 1.0,
                  "MatureHeight": 3.5,
                  "MaturePrunedHeight": 3.0,
                  "MatureWidth": 4.0,
                  "MaturePrunedWidth": 4.0,
                  "SummerPruneDates": null,
