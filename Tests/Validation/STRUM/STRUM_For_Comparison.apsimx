            {
              "$type": "Models.Core.Simulation, Models",
              "Name": "BareUnderStory3",
              "ResourceName": null,
              "Children": [
                {
                  "$type": "Models.Clock, Models",
                  "Start": "2000-06-21T00:00:00",
                  "End": "2001-07-01T00:00:00",
                  "Name": "Clock",
