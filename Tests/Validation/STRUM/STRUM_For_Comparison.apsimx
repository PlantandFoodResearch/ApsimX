                      "MaximumLeafBiomass": 500.0,
                      "MaximumRootBiomass": 300.0,
                      "AgeAtSimulationStart": 12.0,
                      "YearsToMaxDimension": 12,
                      "CrownShape": 0,
                      "MatureCanopyBaseHeight": 1.0,
