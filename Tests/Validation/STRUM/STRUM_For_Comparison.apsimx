                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Zones;",
                    "using APSIM.Shared.Utilities;",
                    "using Models.Soils;",
                    "using System.Collections.Generic;",
                    "using Models.PMF;",
                    "using Models.Core;",
                    "using System;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable]",
                    "    public class Script : Model",
                    "    {",
                    "        [Link] Clock Clock;",
                    "        [Link] Soil soil;",
                    "        [Link] Irrigation irrigation;",
                    "        [Description(\"Start of sowing window (d-mmm)\")]",
                    "        public string StartDate { get; set; }",
                    "        [Description(\"End of sowing window (d-mmm)\")]",
                    "        public string EndDate { get; set; }",
                    "",
                    "        [EventSubscribe(\"StartOfDay\")]",
                    "        private void OnStartOfDay(object sender, EventArgs e)",
                    "        {",
                    "        if (DateUtilities.WithinDates(StartDate, Clock.Today, EndDate))",
                    "            irrigation.Apply(2, 2300);",
                    "        }",
                    "    }",
                    "}"
                  ],
                  "Parameters": [
                    {
                      "Key": "StartDate",
                      "Value": "1-dec"
                    },
                    {
                      "Key": "EndDate",
                      "Value": "1-mar"
                    }
                  ],
                  "Name": "WaterTable",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": false,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Manager, Models",
                  "CodeArray": [
                    "using Models.Soils;",
                    "using System;",
                    "using Models.Core;",
                    "using System.Collections.Generic;",
                    "using System.Text;",
                    "using Models.PMF;",
                    "using Models;",
                    "using System.Xml.Serialization;",
                    "using APSIM.Shared.Utilities;",
                    "using System.Data;",
                    "",
                    "namespace Models",
                    "{",
                    "    [Serializable] ",
                    "    //[System.Xml.Serialization.XmlInclude(typeof(Model))]",
                    "    public class Script : Model",
                    "    {",
                    "        ",
                    "    ",
                    "        ",
                    "        ",
                    "        [Description(\"Days after start\")]",
                    "        public double DAS { get; set; }",
                    "        ",
                    "         [EventSubscribe(\"StartOfSimulation\")]",
                    "        private void DoStartOfSimulation(object sender, EventArgs e)",
                    "        {",
                    "            DAS = 0;",
                    "        }",
                    "        ",
                    "        [EventSubscribe(\"DoReportCalculations\")]",
                    "        private void OnDoReportCalculations(object sender, EventArgs e)",
                    "        {",
                    "            DAS += 1;",
                    "        }",
                    "    ",
                    "    }",
                    "}",
                    "                "
                  ],
