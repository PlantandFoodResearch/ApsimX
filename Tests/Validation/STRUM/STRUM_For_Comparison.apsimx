            {
              "$type": "Models.Core.Simulation, Models",
              "Name": "Manawatu_97",
              "ResourceName": null,
              "Children": [
                {
                  "$type": "Models.Memo, Models",
                  "Text": "*\tBased on Mpelasako et 2001.\n\n*\tLysimeter (1.2 m deep by 1 m wide) trial conducted during the 1997/98 season.\n\n*\tLocation: Massey University, Palmerston North (40°2'S, 175°4'E.\n\n*\tSoil: Manawatu fine sandy loam.\n\n*\tPlant material: 4-year-old 'Braeburn' on MM106 rootstock \n\n*\tFull bloom assumed to be 20/10/1997 - date estimated to be similar to Mills et al (1997)",
                  "Name": "Experiment description",
                  "ResourceName": null,
                  "Children": [],
                  "Enabled": false,
                  "ReadOnly": false
                },
                {
                  "$type": "Models.Clock, Models",
                  "Start": "1997-06-21T00:00:00",
                  "End": "1998-04-20T00:00:00",
                  "Name": "Clock",
                  "ResourceName": null,
                  "Children": [],
