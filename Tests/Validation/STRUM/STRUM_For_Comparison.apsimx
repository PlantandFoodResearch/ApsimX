                    {
                      "$type": "Models.PMF.SimplePlantModels.StrumTreeInstance, Models",
                      "TreeType": "Deciduous",
                      "RowSpacing": 10.0,
                      "InterRowSpacing": 1.0,
                      "AlleyZoneWidthFrac": 0.0,
                      "BudBreakDate": "30-Aug",
                      "StartFullCanopyDate": "24-Oct",
                      "StartLeafFallDate": "22-Apr",
                      "EndLeafFallDate": "17-May",
                      "DBHatMaturity": 12.0,
                      "TypicalCanopyArea": 8.0,
                      "WoodBulkDensity": 650.0,
                      "WoodStorageFraction": 0.0,
                      "MaximumLeafBiomass": 500.0,
                      "MaximumRootBiomass": 300.0,
                      "AgeAtSimulationStart": 12.0,
                      "YearsToMaxDimension": 12,
                      "CrownShape": 0,
                      "MatureCanopyBaseHeight": 1.0,
                      "MaturePrunedCanopyBaseHeight": 1.0,
                      "MatureHeight": 3.5,
                      "MaturePrunedHeight": 3.5,
                      "MatureWidth": 3.0,
                      "MaturePrunedWidth": 2.0,
                      "SummerPruneDates": null,
                      "FRemoveSummerPrune": 0.0,
                      "RootNConc": 0.01,
                      "LeafNConc": 0.02,
                      "WoodNConc": 0.005,
                      "FruitNConc": 0.02,
                      "NFixationFrac": 0.0,
                      "GRINZ": true,
                      "MaxRD": 3.0,
                      "ExtinctCoeff": 0.6,
                      "BaseCover": 0.0,
                      "MaxCover": 0.95,
                      "RUE": 1.2,
                      "PSBaseT": 5.0,
                      "PSLOptT": 20.0,
                      "PSUOptT": 25.0,
                      "PSMaxT": 35.0,
                      "GSMax": 0.006,
                      "R50": 100.0,
                      "SurfaceKL": 0.1,
                      "WaterStress": false,
                      "Number": 50,
                      "PotentialFWPerFruit": 70.0,
                      "DMC": 0.14,
                      "FruitDensity": 0.75,
                      "DateMaxBloom": "1-oct",
                      "DAFStartLinearGrowth": 30,
                      "DAFEndLinearGrowth": 90,
