                    },
                    {
                      "$type": "Models.PMF.Plant, Models",
                      "Name": "STRUM",
                      "ResourceName": "STRUM",
                      "Children": [],
                      "Enabled": false,
                      "ReadOnly": false
                    },
                    {
                      "$type": "Models.PMF.SimplePlantModels.StrumTreeInstance, Models",
                      "TreeType": "Evergreen",
                      "RowSpacing": 4.0,
                      "InterRowSpacing": 1.0,
                      "AlleyZoneWidthFrac": 0.0,
                      "BudBreakDate": "10-Aug",
                      "StartFullCanopyDate": "8-Mar",
                      "StartLeafFallDate": "27-Apr",
                      "EndLeafFallDate": "16-Jun",
                      "DBHatMaturity": 20.0,
                      "TypicalCanopyArea": 12.0,
                      "WoodBulkDensity": 650.0,
